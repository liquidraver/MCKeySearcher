# Test Makefile for OpenSSL Ed25519
TARGET = test_ed25519
SRC = test_openssl_ed25519.cpp
CXX = g++

# Basic compilation flags
CXX_FLAGS = -std=c++17 -O2 -Wall -Wextra

# Link with OpenSSL
LIBS = -lssl -lcrypto

# Default target
all: $(TARGET)

# Build the test program
$(TARGET): $(SRC)
	$(CXX) $(CXX_FLAGS) $(SRC) $(LIBS) -o $(TARGET)

# Run the test
test: $(TARGET)
	./$(TARGET)

# Clean
clean:
	rm -f $(TARGET) *.o

# Install dependencies
install-deps:
	sudo apt-get update
	sudo apt-get install -y build-essential libssl-dev

.PHONY: all test clean install-deps
